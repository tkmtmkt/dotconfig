# Nix設定
if [[ -f ~/.nix-profile/etc/profile.d/nix.sh ]]; then
  . ~/.nix-profile/etc/profile.d/nix.sh
fi

# ローカルbinをPATHに追加する
if ! [[ "$PATH" =~ "$HOME/.local/bin:$HOME/bin:" ]]
then
  export PATH="$HOME/.local/bin:$HOME/bin:$PATH"
fi

# 環境変数設定
export EDITOR=vim
export HISTTIMEFORMAT="[%F %T %Z] "

